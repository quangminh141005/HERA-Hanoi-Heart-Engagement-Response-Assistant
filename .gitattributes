# Raw hospital snapshots are checksum inputs and currently have mixed source
# line endings. Preserve their bytes exactly on every OS so manifest hashes do
# not break after clone/checkout. Generated/curated JSON is deterministic LF.
data/BHYT.json -text
data/gia_dich_vu_ky_thuat_2025.json -text
data/gia_dich_vu_ky_thuat_2025_rag.json -text
data/schedules/**/*.json -text
data/source/**/*.json text eol=lf
data/test-fixtures/**/*.json text eol=lf
data/generated/**/*.json text eol=lf
apps/backend/data/*.json.gz binary
apps/backend/data/*.sha256 text eol=lf
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
