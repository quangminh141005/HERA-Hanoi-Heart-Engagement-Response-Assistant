# HERA environment template. Copy to .env and fill real values locally.

# Application
APP_NAME=HERA - Hanoi Heart Engagement Response Assistant
APP_VERSION=0.1.0
APP_DEBUG=true
ENVIRONMENT=development
SERVICE_NAME=hera-api
LOG_LEVEL=INFO
LOG_FORMAT=json
API_V1_STR=/api/v1

# Backend database
DATABASE_URL=postgresql+psycopg://hera:hera_password@localhost:5432/hera
DB_POOL_SIZE=3
DB_MAX_OVERFLOW=2
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_RECYCLE_SECONDS=1800

# Docker Compose database
POSTGRES_DB=hera
POSTGRES_USER=hera
POSTGRES_PASSWORD=hera_password
DOCKER_DATABASE_URL=postgresql+psycopg://hera:hera_password@db:5432/hera

# CORS
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
CORS_EXTRA_ORIGINS=
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_STORAGE=memory
RATE_LIMIT_ALLOW_MEMORY_IN_PRODUCTION=false
REDIS_URL=redis://localhost:6379/0
DOCKER_RATE_LIMIT_STORAGE=redis
DOCKER_REDIS_URL=redis://redis:6379/0
RATE_LIMIT_DEFAULT_PER_MINUTE=120
RATE_LIMIT_CHAT_PER_MINUTE=30
RATE_LIMIT_HEALTH_PER_MINUTE=300

# Hospital public channels
HOSPITAL_NAME=Hanoi Heart Hospital
HOSPITAL_PUBLIC_BASE_URL=https://benhvientimhanoi.vn
HOSPITAL_HOTLINE=
EMERGENCY_HOTLINE=115

# Hospital APIs
# TODO: configure only after official appointment, schedule, pricing, and auth contracts exist.
HOSPITAL_API_BASE_URL=
HOSPITAL_API_TIMEOUT_SECONDS=5

# RAG LLM providers
# Use FPT Cloud/OpenAI-compatible API as the primary generator.
LLM_PROVIDER=fpt
LLM_FALLBACK_PROVIDER=gemini
LLM_MODEL=your-fpt-chat-model
OPEN_API_KEY=
OPEN_API_BASE_URL=https://mkp-api.fptcloud.com
OPEN_API_EMBEDDING_MODEL=Vietnamese_Embedding
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Embeddings and vector store placeholders
EMBEDDING_PROVIDER=fpt
EMBEDDING_MODEL=Vietnamese_Embedding
EMBEDDING_DIMENSIONS=1536
VECTOR_STORE_PROVIDER=none
VECTOR_STORE_COLLECTION=hera_official_knowledge
RAG_TOP_K=5
RAG_MIN_CONFIDENCE=0.55

# Prometheus metrics
PROMETHEUS_METRICS_ENABLED=true
PROMETHEUS_METRICS_PATH=/metrics

# Langfuse tracing
LANGFUSE_ENABLED=false
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_SAMPLE_RATE=0.2
LANGFUSE_CAPTURE_CONTENT=false
LANGFUSE_TRACE_INPUT_MAX_CHARS=500
LANGFUSE_TRACE_OUTPUT_MAX_CHARS=1000
