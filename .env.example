# HERA hackathon configuration. Copy this file to .env and fill every blank
# secret locally. The real .env is ignored by Git and must never be committed.

# Public gateway
HERA_BIND_ADDRESS=127.0.0.1
HERA_HTTP_PORT=8080
PUBLIC_BASE_URL=http://localhost:8080
CORS_ORIGINS=["http://localhost:8080"]
VITE_EMBED_PARENT_ORIGINS=https://benhvientimhanoi.vn,https://www.benhvientimhanoi.vn
HERA_IMAGE_TAG=local
HERA_API_IMAGE_REPOSITORY=hera-api
HERA_WEB_IMAGE_REPOSITORY=hera-web

# Application
APP_VERSION=0.1.0
APP_DEBUG=false
ENVIRONMENT=hackathon
LOG_LEVEL=INFO
REFERENCE_DATE_MODE=dataset_start
TREAT_PROVIDED_DATA_AS_LATEST=true
ALLOW_REVIEW_ONLY_DATA=false
LOG_RAW_MESSAGES=false
CHAT_MAX_CHARS=2000
EPHEMERAL_CONTEXT_TTL_MINUTES=30
CONSENTED_MESSAGE_TTL_DAYS=7
CONVERSATION_MEMORY_BACKEND=redis
STRUCTURED_CACHE_ENABLED=true
STRUCTURED_CACHE_TTL_SECONDS=300
STRUCTURED_CACHE_MAX_PAYLOAD_BYTES=524288
REDIS_MAXMEMORY=256mb

# PostgreSQL. Use random URL-safe values; do not reuse a personal password.
POSTGRES_DB=hera
POSTGRES_USER=hera_owner
POSTGRES_PASSWORD=

# Model gateway (OpenAI-compatible FPT endpoint)
# API_KEY is the key described by ../.env, LLM.md and Embedding.md.
API_KEY=
LLM_PROVIDER=openai
FPT_API_BASE_URL=https://mkp-api.fptcloud.com
FPT_LLM_MODEL=gpt-oss-120b
FPT_GUARD_MODEL=gpt-oss-20b
FPT_EMBEDDING_MODEL=Vietnamese_Embedding
LLM_TIMEOUT_SECONDS=30
AI_PROVIDER_RETRY_MAX_ATTEMPTS=2
AI_PROVIDER_RETRY_BASE_DELAY_SECONDS=0.25
AI_PROVIDER_RETRY_MAX_DELAY_SECONDS=2
LLM_MAX_CONCURRENT_REQUESTS=2
LLM_QUEUE_TIMEOUT_SECONDS=2
LLM_RESPONSE_CACHE_ENABLED=true
LLM_RESPONSE_CACHE_TTL_SECONDS=300
LLM_RESPONSE_CACHE_MAX_ENTRIES=512
EMBEDDING_TIMEOUT_SECONDS=10
CHAT_OVERALL_TIMEOUT_SECONDS=35
MODEL_ROUTING_ENABLED=true
MODEL_ROUTING_TIMEOUT_SECONDS=6
MODEL_ROUTING_MAX_TOKENS=1024
MODEL_ROUTING_EMERGENCY_CONFIDENCE_THRESHOLD=0.62
MODEL_ROUTING_INTENT_CONFIDENCE_THRESHOLD=0.60
MODEL_TIMEOUT_SECONDS=45
MODEL_PROBE_LLM_MAX_TOKENS=1024
HARD_EVAL_JUDGE_MAX_TOKENS=1024
HARD_EVAL_DELAY_SECONDS=2.1
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=Vietnamese_Embedding
EMBEDDING_DIMENSIONS=1024
EMBEDDING_BASE_URL=https://mkp-api.fptcloud.com
# Structured lookup and semantic retrieval both use PostgreSQL + pgvector.
VECTOR_STORE_PROVIDER=pgvector
RAG_TOP_K=3
RAG_GENERATION_MAX_TOKENS=1024
RAG_HYDE_ENABLED=true
RAG_HYDE_MAX_TOKENS=1024
RAG_HYDE_MAX_CHARS=700
RERANK_ENABLED=true
RERANK_MODEL=bge-reranker-v2-m3
RERANK_TOP_N=3
RERANK_TIMEOUT_SECONDS=8
RERANK_MAX_CONCURRENT_REQUESTS=4
RERANK_CACHE_ENABLED=true
RERANK_CACHE_TTL_SECONDS=300
RERANK_CACHE_MAX_ENTRIES=512

# Prototype booking. These values are valid only for hackathon/test.
BOOKING_PROVIDER=local_prototype
DEFAULT_DOCTOR_CAPACITY_PER_SESSION=20
BOOKING_HOLD_TTL_SECONDS=300
BOOKING_REQUIRE_APPROVED_DOCTOR=true
BOOKING_REQUIRE_APPROVED_CAPACITY_RULE=false
BOOKING_ALLOW_PROJECT_MVP_RULE=true
BOOKING_MAX_ACTIVE_HOLDS_PER_ANONYMOUS_SESSION=2
HOLD_TOKEN_SECRET=
BOOKING_PII_HASH_SECRET=

# Shared rate limiting and metrics
RATE_LIMIT_ENABLED=true
RATE_LIMIT_STORAGE=redis
TRUST_PROXY_HEADERS=true
TRUSTED_PROXY_CIDRS=["127.0.0.1/32","::1/128","172.16.0.0/12"]
PROMETHEUS_METRICS_ENABLED=true
DOCKER_LOG_MAX_SIZE=10m
DOCKER_LOG_MAX_FILES=5

# Approved public channels; leave blank until verified by the data owner.
HOSPITAL_HOTLINE=
HOSPITAL_NAME=Hanoi Heart Hospital
HOSPITAL_PUBLIC_BASE_URL=https://benhvientimhanoi.vn
EMERGENCY_HOTLINE=115

# Optional tracing. Content capture remains disabled.
LANGFUSE_ENABLED=true
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
# Optional SDK-compatible alias; if set, it overrides LANGFUSE_HOST.
LANGFUSE_BASE_URL=
LANGFUSE_SAMPLE_RATE=1
LANGFUSE_CAPTURE_CONTENT=true

# Optional local monitoring (docker-compose.monitoring.yml)
MONITORING_BIND_ADDRESS=127.0.0.1
PROMETHEUS_PORT=19090
PROMETHEUS_RETENTION=15d
PROMETHEUS_IMAGE=prom/prometheus:v3.13.1
GRAFANA_PORT=13000
GRAFANA_IMAGE=grafana/grafana:12.4.0
GRAFANA_ROOT_URL=http://localhost:13000
GRAFANA_COOKIE_SECURE=false
GRAFANA_ADMIN_USER=hera_admin
GRAFANA_ADMIN_PASSWORD=
